<table border="1" cellpadding="4">
  <thead>
    <tr>
      <th>ID</th>
      <th>Formula</th>
      <th>Name</th>
      <th>Spacegroup</th>
    </tr>
  </thead>
  <tbody>
    {% for row in result %}
    <tr>
      <td>
        <a href="{{ page.relbaseurl }}/index.html?q={{ query.get('q', '') }}&material_id={{ row['id'] }}">
          {{ row['id'] }}
        </a>
      </td>
      <td>{{ row['formula'] }}</td>
      <td>{{ row['name'] }}</td>
      <td>{{ row['spacegroup'] }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
